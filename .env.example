# ReviQ Environment Configuration
# Copy this file to .env and adjust as needed

# Port configuration
BACKEND_PORT=8000
FRONTEND_PORT=3000

# BibTeX base directory (host path mounted into the container)
# Place your .bib files here following the convention:
#   <BIB_BASE_DIR>/db_search/<database_name>.bib
#   <BIB_BASE_DIR>/snowballing/iteration_01/forward_citations.bib
BIB_BASE_DIR=./bib_data
