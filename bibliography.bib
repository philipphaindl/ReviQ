	file = {PDF:/Users/lbhaindlp/Zotero/storage/W37VBUK2/Frenzel et al. - 2018 - Tracing of Multi-Threaded Java Applications in Score-P Using Bytecode Instrumentation.pdf:application/pdf},
}

